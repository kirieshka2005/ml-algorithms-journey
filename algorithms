   "source": [
    "**Сложность работы алгоритма О(log(N))**"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "535b6375-8844-428f-ab8f-1cc0930d736e",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Реализуем функцию бинарного поиска, в предположении что массив отсортирован\n",
    "def binary_search(arr, target):\n",
    "    low = 0\n",
    "    high = len(arr) - 1\n",
    "    while low <= high:\n",
    "        mid = (high + low) // 2\n",
    "        guess = arr[mid]\n",
    "        if guess == target:\n",
    "            return mid\n",
    "        elif guess < target:\n",
    "            low = mid + 1\n",
    "        else:\n",
    "            high = mid - 1\n",
    "    return None"
   ]
  },
